{
  "expo": {
    "name": "AgentCicle",
    "slug": "agentcicle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "entryPoint": "./index",
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3ECE3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agentcicle.app",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.agentcicle.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-logo.png",
        "backgroundColor": "#F3ECE3"
      }
    },
    "web": {
      "favicon": "./assets/favicon-logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
      }
    }
  }
}
